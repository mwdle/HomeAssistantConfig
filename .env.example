# Define each variable appropriately and rename this file to .env, it will be used by compose.yaml

# The user ID the container(s) will run as
UID=1000
# The group ID the container(s) will run as
GID=1000

# Base path on the host for all persistent Docker data (volumes)
DOCKER_VOLUMES=/path/to/your/docker/volumes
# The group ID of the 'docker' group on the host machine (used by Glances to provide Docker stats)
# REPLACE THIS WITH THE VALUE RETURNED BY `getent group docker | cut -d: -f3` ON YOUR MACHINE - this step only has to be performed once
DOCKER_GID=976

# Frigate & Home Assistant Variables
MQTT_USER=your_mqtt_username
MQTT_PASSWORD='your_mqtt_password'

# Music Assistant Variables
MUSIC_VOLUME=/path/to/your/music/directory

# Router Rebooter Variables
ROUTER_PASSWORD='your_router_password'
EXTENDER_PASSWORD='your_extender_password'

# Home Assistant Matter Hub Variables
HA_ACCESS_TOKEN='access_token_for_your_home_assistant_instance'